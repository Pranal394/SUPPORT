{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "user"] },
        "assignedDepartments": { "type": "array", "description": "Departments this user can manage if they are staff/admin" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "Support ticket for a specific department",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "description": { "type": "string" },
        "department": { "type": "string", "enum": ["Shards Connect", "Shards Shields", "Shards Security", "Suraksha Sankalp - Shards Connect", "Cif Shards Connect"] },
        "status": { "type": "string", "enum": ["open", "pending", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "description", "department", "status", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message within a ticket",
      "type": "object",
      "properties": {
        "ticketId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderEmail": { "type": "string" },
        "senderRole": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["ticketId", "senderId", "text", "timestamp"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Record of administrative actions",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminEmail": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "details": { "type": "string" },
        "department": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["adminId", "action", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Collection of support tickets"
    },
    "tickets/{ticketId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages for a specific ticket"
    },
    "auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Collection of administrative audit logs"
    }
  }
}
